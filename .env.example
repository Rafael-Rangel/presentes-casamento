# --- Supabase (obrigatório) ---
# No dashboard aparece algo como:
#   https://SEU_REF.supabase.co/rest/v1/
# Em .env usa só a BASE (sem /rest/v1/):
#   NEXT_PUBLIC_SUPABASE_URL=https://SEU_REF.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Settings → API Keys:
#   "Publishable" → NEXT_PUBLIC_SUPABASE_ANON_KEY (sb_publishable_… ou JWT anon legacy)
#   "Secret" (default) → SUPABASE_SERVICE_ROLE_KEY (sb_secret_… ou JWT service_role legacy)
# Nunca uses a secret no browser nem em NEXT_PUBLIC_*.
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# URL pública do site (magic link, /auth/callback, emails, OG). Em dev: http://localhost:3000
# Produção (ex.): https://casamento-rafael-adrielly.netlify.app — deve coincidir com o Site URL no Supabase.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Data mostrada na home / convite (texto livre)
NEXT_PUBLIC_WEDDING_DATE=12 de dezembro de 2026

# Painel noivos (senha partilhada pelos dois; não é utilizador Supabase)
ADMIN_PASSWORD=
# Segredo para assinar o cookie de sessão do admin (mín. 16 caracteres aleatórios)
ADMIN_SESSION_SECRET=

# Cron (Netlify: função agendada chama /api/cron/* com este segredo; na Netlify define CRON_SECRET).
# Em Vercel (se usares) o header Bearer também pode ser enviado por cron.
CRON_SECRET=

# E-mail transacional (opcional — Gmail com "palavra-passe de app")
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=
EMAIL_FROM_NAME=Casamento

# Web Push (opcional, futuro)
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
